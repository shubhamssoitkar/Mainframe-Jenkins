//DB2RUN   JOB ,MSGLEVEL=(2,1),CLASS=7,NOTIFY=&SYSUID
//EXP EXPORT SYMLIST=*
//SYM SET DB2PGM=COBPGM1
//DSNTSO   EXEC PGM=IKJEFT01
//STEPLIB  DD DISP=SHR,DSN=Z10791.LOAD
