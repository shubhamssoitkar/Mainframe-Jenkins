//SYSTSPRT DD SYSOUT=*
//SYSTSIN  DD *,SYMBOLS=EXECSYS
DSN SYSTEM(DBDG)
RUN PROGRAM(COBPGM1) PLAN(Z10791) -
    LIB('Z10791.LOAD')
