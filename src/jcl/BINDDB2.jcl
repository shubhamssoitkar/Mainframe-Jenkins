//DB2BIND JOB
// EXPORT SYMLIST=(SSID,PROGRAM)
// SET SSID=DBDG
// SET PROGRAM=COBPGM01
//DSNTSO EXEC PGM=IKJEFT01,REGION=0M
//STEPLIB DD DISP=SHR,DSN=ZXP.PUBLIC.LOAD
// DD DISP=SHR,DSN=DSND10.SDSNLOAD
// DD DISP=SHR,DSN=DSND10.SDSNLOD2
//SYSTSPRT DD SYSOUT=*
//SYSTSIN DD *,SYMBOLS=EXECSYS
    DSN SYSTEM(&SSID.)
    BIND PLAN(&SYSUID.) -
    MEMBER(&PROGRAM.) -
    LIBRARY(‘&SYSUID..DBRMLIB’) -
    ACTION(REPLACE) -
    RETAIN -
    VALIDATE(RUN)
END